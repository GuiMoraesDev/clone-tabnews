{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Implementação do https://www.tabnews.com.br para o https://curso.dev",
  "main": "index.js",
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "dev:database": "docker compose -f ./src/infra/compose.yaml up -d",
    "dev:web-client": "next dev --turbopack",
    "dev": "pnpm dev:database && pnpm dev:web-client",
    "build": "next build",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "check-types": "tsc --noEmit --incremental false",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "next": "15.5.4",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/react": "19.2.0",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
